# ===================================================================
# Oracle Database Configuration
# ===================================================================
# Thay thế config MySQL cũ. Đổi giá trị cho phù hợp với Oracle của bạn.
# ===================================================================

# Format: host:port/service_name
DB_CONNECT=localhost:1521/orcl
# User schema (đã tạo bằng setup_oracle.sql)

DB_USER=ecom_user
DB_PASSWORD=StrongPass123
# JWT cho authentication
JWT_SECRET=123456
JWT_EXPIRES_IN=24h

# Server
PORT=3000
NODE_ENV=development

# CORS - frontend URL
FRONTEND_URL=http://localhost:3001
